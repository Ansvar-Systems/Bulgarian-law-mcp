{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Bulgarian Law MCP",
  "description": "Golden contract tests for real-data Bulgarian Law MCP ingestion from parliament.bg",
  "tests": [
    {
      "id": "bg-001",
      "category": "article_retrieval",
      "description": "Retrieve Cybersecurity Act (2018) Art. 1",
      "tool": "get_provision",
      "input": {
        "document_id": "cybersecurity-act-2018",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Този закон урежда", "киберсигурността"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "bg-002",
      "category": "article_retrieval",
      "description": "Retrieve Electronic Identification Act (2016) Art. 1",
      "tool": "get_provision",
      "input": {
        "document_id": "electronic-identification-act-2016",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["електронната идентификация"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "bg-003",
      "category": "article_retrieval",
      "description": "Retrieve Crypto-Asset Markets Act (2025) Art. 1",
      "tool": "get_provision",
      "input": {
        "document_id": "crypto-asset-markets-act-2025",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["криптоактиви"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "bg-004",
      "category": "search",
      "description": "Full-text search for cybersecurity",
      "tool": "search_legislation",
      "input": {
        "query": "киберсигурност"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["киберсигурност"]
      }
    },
    {
      "id": "bg-005",
      "category": "search",
      "description": "Full-text search for crypto-assets",
      "tool": "search_legislation",
      "input": {
        "query": "криптоактиви"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["криптоактиви"]
      }
    },
    {
      "id": "bg-006",
      "category": "citation_roundtrip",
      "description": "Citation for Cybersecurity Act uses parliament.bg URL",
      "tool": "get_provision",
      "input": {
        "document_id": "cybersecurity-act-2018",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "parliament\\.bg",
        "text_not_empty": true
      }
    },
    {
      "id": "bg-007",
      "category": "negative_test",
      "description": "Non-existent law returns graceful empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "Несъществуващ закон",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "bg-008",
      "category": "negative_test",
      "description": "Malformed section returns graceful empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "cybersecurity-act-2018",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
